@page "/login"
@page "/"
@layout EmptyLayout
@inject AppStateService AppState
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">🐾</div>
            <div class="login-title">VetMS</div>
            <div class="login-subtitle">Veterinary Management System</div>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="login-error">⚠️ @error</div>
            }
            <div class="form-group">
                <label class="form-label">Username</label>
                <input class="form-control" type="text" @bind="username" @bind:event="oninput"
                       placeholder="Enter username" @onkeyup="OnKeyUp" />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input class="form-control" type="password" @bind="password" @bind:event="oninput"
                       placeholder="Enter password" @onkeyup="OnKeyUp" />
            </div>
            <button class="btn btn-primary w-100" style="margin-top:8px;padding:11px" @onclick="DoLogin" disabled="@loading">
                @if (loading) { <span>Signing in...</span> } else { <span>Sign In</span> }
            </button>
            <p style="text-align:center;margin-top:14px;font-size:12px;color:var(--text-muted)">
                Default: admin / admin123
            </p>
        </div>
    </div>
</div>

@code {
    string username = "admin";
    string password = "admin123";
    string error = "";
    bool loading = false;

    protected override void OnInitialized()
    {
        if (AppState.IsAuthenticated) Nav.NavigateTo("/dashboard");
    }

    void OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoLogin();
    }

    void DoLogin()
    {
        error = "";
        loading = true;
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please enter username and password.";
            loading = false;
            return;
        }
        bool ok = AppState.Login(username.Trim(), password);
        loading = false;
        if (ok)
            Nav.NavigateTo("/dashboard");
        else
            error = "Invalid username or password.";
    }
}
