@page "/service-types"
@inject AppStateService AppState
@inject IServiceTypeService Svc
@inject ToastService Toast

@{AppState.PageTitle = "Service Types";}

<div class="page-header">
    <div><div class="page-title">Service Types</div></div>
    <button class="btn btn-primary" @onclick="() => OpenModal(null)">+ New Service</button>
</div>

<div class="card">
    <div class="card-body" style="padding-bottom:8px">
        <div class="toolbar">
            <div class="search-box"><span class="search-icon">🔍</span><input placeholder="Search..." @bind="search" @bind:event="oninput" @oninput="Filter" /></div>
        </div>
    </div>
    <div class="table-wrap">
        <table>
            <thead><tr><th>#</th><th>Name</th><th>Category</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (filtered.Count == 0)
                { <tr><td colspan="6"><div class="empty-state"><div class="empty-icon">💉</div><div class="empty-msg">No services found.</div></div></td></tr> }
                @foreach (var s in filtered)
                {
                    <tr>
                        <td class="text-muted text-sm">@s.Id</td>
                        <td><strong>@s.Name</strong></td>
                        <td>@s.Category</td>
                        <td>$@s.Price.ToString("N2")</td>
                        <td><span class="badge @(s.IsActive?"badge-success":"badge-gray")">@(s.IsActive?"Active":"Inactive")</span></td>
                        <td><div class="td-actions">
                            <button class="btn btn-sm btn-secondary" @onclick="() => OpenModal(s)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => AskDelete(s)">Delete</button>
                        </div></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header"><span>@(editing.Id==0?"New Service":"Edit Service")</span><button class="modal-close" @onclick="CloseModal">✕</button></div>
            <div class="modal-body">
                <div class="form-group"><label class="form-label">Name *</label><input class="form-control" @bind="editing.Name" /></div>
                <div class="form-row">
                    <div class="form-group"><label class="form-label">Category</label><input class="form-control" @bind="editing.Category" placeholder="e.g. Vaccination, Surgery" /></div>
                    <div class="form-group"><label class="form-label">Price</label><input class="form-control" type="number" step="0.01" @bind="editing.Price" /></div>
                </div>
                <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" rows="2" @bind="editing.Description"></textarea></div>
                <div class="form-group"><label style="display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" @bind="editing.IsActive" /> Active</label></div>
                @if (!string.IsNullOrEmpty(formError)) { <div class="login-error">⚠️ @formError</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save">Save</button>
            </div>
        </div>
    </div>
}

<ConfirmModal Visible="showConfirm" Title="Delete Service" Message="@($"Delete {deleteTarget?.Name}?")"
    OnConfirm="ConfirmDelete" OnCancel="() => showConfirm = false" />

@code {
    List<ServiceType> all = [], filtered = [];
    string search = "", formError = "";
    bool showModal, showConfirm;
    ServiceType editing = new();
    ServiceType? deleteTarget;

    protected override void OnInitialized() => Load();
    void Load() { all = Svc.GetAll(); Filter(); }
    void Filter() => filtered = all.Where(s => string.IsNullOrEmpty(search) || s.Name.Contains(search, StringComparison.OrdinalIgnoreCase) || s.Category.Contains(search, StringComparison.OrdinalIgnoreCase)).ToList();

    void OpenModal(ServiceType? s)
    {
        formError = "";
        editing = s == null ? new ServiceType { IsActive = true } :
                  new ServiceType { Id=s.Id, Name=s.Name, Category=s.Category, Price=s.Price, Description=s.Description, IsActive=s.IsActive };
        showModal = true;
    }
    void CloseModal() { showModal = false; formError = ""; }

    void Save()
    {
        formError = "";
        if (string.IsNullOrWhiteSpace(editing.Name)) { formError = "Name is required."; return; }
        editing.Category ??= ""; editing.Description ??= "";
        try
        {
            if (editing.Id == 0) Svc.Insert(editing); else Svc.Update(editing);
            Toast.Success("Saved."); CloseModal(); Load();
        }
        catch (Exception ex) { formError = ex.Message; }
    }

    void AskDelete(ServiceType s) { deleteTarget = s; showConfirm = true; }
    void ConfirmDelete()
    {
        if (deleteTarget == null) return;
        try { Svc.Delete(deleteTarget); Toast.Success("Deleted."); showConfirm = false; Load(); }
        catch (Exception ex) { Toast.Error(ex.Message); showConfirm = false; }
    }
}
