@inherits LayoutComponentBase
@inject AppStateService AppState
@inject NavigationManager Nav

@if (!AppState.IsAuthenticated)
{
    @Body
}
else
{
    <div class="shell">
        <Sidebar />
        <div class="main-area">
            <div class="topbar">
                <span class="topbar-title">@AppState.PageTitle</span>
                <span class="topbar-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</span>
            </div>
            <div class="content">
                @Body
            </div>
        </div>
    </div>
    <ToastHost />
}
